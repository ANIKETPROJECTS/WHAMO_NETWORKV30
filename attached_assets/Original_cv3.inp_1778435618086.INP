c ************************************************************
c TURBINE CHARACTERISTICS (MATCHED TO ~50 FT HEAD SYSTEM)

TCHAR TYPE 1
 GATE 20. 40. 60. 80. 100.
 HEAD 60. 50. 40. 30. 20.
 Q
   40.  80. 120. 160. 200.
   36.  72. 108. 144. 180.
   30.  60.  90. 120. 150.
   24.  48.  72.  96. 120.
   16.  32.  48.  64.  80.
 EFFICIENCY
   0.75 0.85 0.90 0.92 0.93
   0.73 0.83 0.88 0.90 0.91
   0.70 0.80 0.85 0.87 0.88
   0.65 0.75 0.80 0.82 0.83
   0.60 0.70 0.75 0.77 0.78
FINISH

c ************************************************************
c TURBINE OPERATION (SMOOTH – NO SHOCK)

OPTURB
 ID T1
 GENERATE
 VSCHEDULE 1
FINISH

OPTURB
 ID T2
 GENERATE
 VSCHEDULE 2
FINISH

c ************************************************************
c GATE SCHEDULES (VERY IMPORTANT FOR STABILITY)

SCHEDULE
 VSCHEDULE 1
   T 0.0   G 100.0
   T 50.0  G 80.0
   T 100.0 G 60.0
   T 150.0 G 40.0
   T 200.0 G 20.0
FINISH

SCHEDULE
 VSCHEDULE 2
   T 0.0   G 100.0
   T 200.0 G 100.0
FINISH

c ************************************************************
c OUTPUT

HISTORY
 NODE 1 Q HEAD
 NODE 4 Q HEAD
 NODE 6 Q HEAD
 NODE 9 Q HEAD
 ELEM T1 Q HEAD SPEED POWER
 ELEM T2 Q HEAD SPEED POWER
FINISH

DISPLAY
 ALL
FINISH

c ************************************************************
c CONTROL

CONTROL
 DTCOMP 0.1
 DTOUT 0.5
 TMAX 200.0
FINISH

GO
GOODBYE